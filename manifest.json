{
  "manifest_version": 3,
  "name": "Onsite Apply Assistant",
  "version": "1.0.0",
  "description": "网申助手 — 自动从个人主页同步简历数据，一键填写任意网申表单",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*", "audio/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "网申助手"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+Q" },
      "description": "打开/收起网申助手侧边栏"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
